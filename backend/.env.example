# Copy to .env and fill in your keys.

# Anthropic API key — required for report generation.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for the report.
ANTHROPIC_MODEL=claude-sonnet-5

# NewsAPI.org developer key — required for the news tool.
# Free tier: https://newsapi.org/register
NEWSAPI_KEY=

# Massive.com (formerly Polygon.io) API key — preferred bulk price source for
# the recommendations screen. Without it, screening falls back to Yahoo
# Finance, which is flakier. Free key: https://massive.com
# Free tier is 5 requests/min: the first sweep backfills ~6 months of daily
# bars (~25 min, cached to massive_daily_cache.json); later sweeps take seconds.
MASSIVE_API_KEY=

# Comma-separated origins allowed to call the API (the React dev server).
CORS_ORIGINS=http://localhost:5173

# Contact info for SEC EDGAR requests (their fair-access policy REQUIRES a real
# address). Use 'AppName/version (you@example.com)'. Without it, the SEC EDGAR
# fundamentals tool refuses to fetch and the financials agent degrades to a flag.
SEC_USER_AGENT=AI-Investment-Research/0.2 (you@example.com)

# --- Phase 3: persistence & auth ---------------------------------------------

# Deployment environment. Leave 'dev' locally. Set to 'prod' (or anything other
# than 'dev') on a deployment — the app then REFUSES TO BOOT unless JWT_SECRET
# is a strong non-default value (≥32 bytes).
ENV=dev

# SQLAlchemy connection string. SQLite default needs no setup; for Postgres use
# e.g. postgresql+psycopg://user:pass@localhost:5432/investment
DATABASE_URL=sqlite:///./investment.db

# Secret for signing JWTs. REQUIRED outside dev. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Token lifetime in minutes (default: 7 days).
JWT_EXPIRE_MINUTES=10080

# --- Phase 2: rate limiting & abuse guards -----------------------------------

# Per-IP rate limits (slowapi syntax, e.g. "5/minute"). Set RATE_LIMIT_ENABLED
# false only for local load tests / test suites.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RESEARCH=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_RUN_NOW=5/minute
RATE_LIMIT_SEND_NOW=3/minute

# Process-wide cap on research runs started per UTC day (0 = unlimited). This is
# the real budget guard against draining Anthropic/NewsAPI spend.
DAILY_RUN_BUDGET=200

# Per-email login lockout after repeated failures.
LOGIN_MAX_FAILURES=10
LOGIN_LOCKOUT_MINUTES=15

# --- Phase 4: scheduled summaries & alert email --------------------------------

# In-process daily summary job (APScheduler). Set false to disable (e.g. tests).
SCHEDULER_ENABLED=true

# When the daily sweep runs (UTC). Default 13:30 UTC ≈ just after US open.
DAILY_SUMMARY_HOUR_UTC=13
DAILY_SUMMARY_MINUTE_UTC=30

# Optional SMTP for alert emails. Leave SMTP_HOST empty to log emails to the
# console instead (dev-friendly default).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
