# Copy to .env and fill in your keys.

# Anthropic API key — required for report generation.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for the report.
ANTHROPIC_MODEL=claude-sonnet-5

# NewsAPI.org developer key — required for the news tool.
# Free tier: https://newsapi.org/register
NEWSAPI_KEY=

# Comma-separated origins allowed to call the API (the React dev server).
CORS_ORIGINS=http://localhost:5173
